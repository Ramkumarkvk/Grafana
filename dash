{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "CPU Total %",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"node_exporter\",instance=~\"$instance\",mode=\"idle\"}[5m])) * 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "RAM Used %",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{job=\"node_exporter\",instance=~\"$instance\"} / node_memory_MemTotal_bytes{job=\"node_exporter\",instance=~\"$instance\"}))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Network Rx",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total{job=\"node_exporter\",instance=~\"$instance\",device!~\"lo|docker.*|veth.*\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Network Tx",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(node_network_transmit_bytes_total{job=\"node_exporter\",instance=~\"$instance\",device!~\"lo|docker.*|veth.*\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Breakdown %",
      "id": 5,
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{job=\"node_exporter\",instance=~\"$instance\",mode=~\"user|system|iowait\"}[5m])) * 100",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Used",
      "id": 6,
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=\"node_exporter\",instance=~\"$instance\"} - node_memory_MemAvailable_bytes{job=\"node_exporter\",instance=~\"$instance\"}",
          "legendFormat": "used",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "type": "table",
      "title": "Disk Usage % (selected mounts)",
      "id": 7,
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{job=\"node_exporter\",instance=~\"$instance\",mountpoint=~\"$mount_regex\",fstype!~\"tmpfs|overlay|squashfs|nsfs|proc|sysfs|devtmpfs\"} / node_filesystem_size_bytes{job=\"node_exporter\",instance=~\"$instance\",mountpoint=~\"$mount_regex\",fstype!~\"tmpfs|overlay|squashfs|nsfs|proc|sysfs|devtmpfs\"}))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "mountpoint": "Mount Point",
              "Value": "Used %"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1 },
        "overrides": []
      },
      "options": { "showHeader": true }
    },
    {
      "type": "timeseries",
      "title": "Network Traffic",
      "id": 8,
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (device) (rate(node_network_receive_bytes_total{job=\"node_exporter\",instance=~\"$instance\",device!~\"lo|docker.*|veth.*\"}[5m]))",
          "legendFormat": "{{device}} - Received",
          "refId": "A"
        },
        {
          "expr": "sum by (device) (rate(node_network_transmit_bytes_total{job=\"node_exporter\",instance=~\"$instance\",device!~\"lo|docker.*|veth.*\"}[5m]))",
          "legendFormat": "{{device}} - Transmitted",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "decimals": 1 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "type": "table",
      "title": "Top 5 Processes by CPU",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "topk(5, sum by (groupname, mode, instance) (rate(namedprocess_namegroup_cpu_seconds_total{job=\"process_exporter\",instance=~\"$instance\"}[5m])) * 100)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "groupname": "Process Name",
              "instance": "Server",
              "mode": "mode",
              "Value": "CPU %"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 2 },
        "overrides": []
      },
      "options": { "showHeader": true }
    },
    {
      "type": "table",
      "title": "Top 5 Processes by Memory",
      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "topk(5, max by (groupname, instance) (namedprocess_namegroup_memory_bytes{job=\"process_exporter\",instance=~\"$instance\"}))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "groupname": "Process Name",
              "instance": "Server",
              "Value": "Memory"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "decimals": 1 },
        "overrides": []
      },
      "options": { "showHeader": true }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["linux", "vm", "metrics", "aqua", "infra"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "refresh": 1,
        "query": "label_values(node_cpu_seconds_total{job=\"node_exporter\"}, instance)",
        "definition": "label_values(node_cpu_seconds_total{job=\"node_exporter\"}, instance)",
        "current": { "selected": false, "text": "", "value": "" },
        "options": [],
        "includeAll": false,
        "multi": false
      },
      {
        "name": "mount_regex",
        "type": "custom",
        "label": "Mount regex",
        "query": "/|/app|/data|/opt|/u01",
        "current": {
          "selected": true,
          "text": "/|/app|/data|/opt|/u01",
          "value": "/|/app|/data|/opt|/u01"
        },
        "options": [
          {
            "selected": true,
            "text": "/|/app|/data|/opt|/u01",
            "value": "/|/app|/data|/opt|/u01"
          }
        ]
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Linux VM Metrics - Clean",
  "uid": "linux-vm-metrics-clean-aqua",
  "version": 1,
  "weekStart": ""
}
